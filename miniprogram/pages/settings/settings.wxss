page {
  background: #f5f5f5;
}

.container {
  padding: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.contact-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
}

.contact-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-info {
  display: flex;
  flex-direction: column;
}

.contact-phone {
  font-size: 30rpx;
  color: #333;
}

.contact-email {
  font-size: 26rpx;
  color: #5856d6;
  margin-top: 6rpx;
}

.contact-name {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.contact-delete {
  font-size: 36rpx;
  color: #ff3b30;
  padding: 10rpx 20rpx;
}

.empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 40rpx;
}

.form {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.form-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.btn-save {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  margin-top: 10rpx;
}

.btn-save::after {
  border: none;
}
