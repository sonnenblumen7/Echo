page {
  height: 100%;
  background: #f5f5f5;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 64rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-top: 10rpx;
}

.card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 60rpx;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.status-row + .status-row {
  border-top: 1rpx solid #f0f0f0;
}

.label {
  font-size: 28rpx;
  color: #999;
}

.value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.value.active {
  color: #07c160;
}

.value.inactive {
  color: #999;
}

.value.sleep {
  color: #5856d6;
}

.sleep-remaining {
  color: #5856d6;
  font-weight: bold;
}

.btn-sleep {
  width: 80%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #5856d6;
  background: #fff;
  border: 2rpx solid #5856d6;
  margin-bottom: 40rpx;
}

.btn-sleep::after {
  border: none;
}

.btn-cancel-sleep {
  color: #ff9500;
  border-color: #ff9500;
}

.btn-main {
  width: 80%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  border: none;
  margin-bottom: 40rpx;
}

.btn-main::after {
  border: none;
}

.btn-start {
  background: linear-gradient(135deg, #07c160, #06ad56);
}

.btn-stop {
  background: linear-gradient(135deg, #ff9500, #ff7b00);
}

.btn-ping {
  width: 80%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #07c160;
  background: #fff;
  border: 2rpx solid #07c160;
  margin-bottom: 40rpx;
}

.btn-ping::after {
  border: none;
}

.sos-wrapper {
  width: 80%;
}

.btn-sos {
  width: 100%;
  height: 140rpx;
  border-radius: 70rpx;
  background: linear-gradient(135deg, #ff3b30, #d63031);
  color: #fff;
  border: none;
  padding: 0;
  box-shadow: 0 8rpx 24rpx rgba(255, 59, 48, 0.3);
  position: relative;
  overflow: hidden;
}

.btn-sos::after {
  border: none;
}

.sos-progress {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  width: 0;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 70rpx;
  transition: none;
}

.sos-progress-active {
  width: 100%;
  transition: width 3s linear;
}

.sos-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.sos-icon {
  font-size: 36rpx;
}

.sos-text {
  font-size: 28rpx;
  font-weight: bold;
}

.sos-hint {
  font-size: 20rpx;
  opacity: 0.8;
  margin-top: 4rpx;
}
