# PushDeer 保底通知通道
# 注册 https://www.pushdeer.com 获取 Key
PUSHDEER_KEY=your_pushdeer_key_here

# SMTP 邮件配置（QQ邮箱）
# 获取授权码：QQ邮箱 → 设置 → 账户 → POP3/SMTP服务 → 开启 → 生成授权码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_qq_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code

# 微信小程序配置
# 获取方式：微信公众平台 → 开发 → 开发管理 → 开发设置
WX_APPID=your_wechat_appid
WX_SECRET=your_wechat_secret
